{
  "name": "virtualrift-frontend",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter virtualrift-dashboard dev",
    "build": "pnpm --filter virtualrift-dashboard build",
    "test": "pnpm exec vitest run",
    "lint": "pnpm --filter '*' lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
